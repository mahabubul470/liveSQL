{
  "name": "@livesql/vue",
  "version": "0.1.0-alpha.2",
  "license": "Apache-2.0",
  "description": "Vue 3 composables for LiveSQL — useLiveQuery, createLiveSQLPlugin",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
