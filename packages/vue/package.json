    "vue": ">=3.0.0"
  },
  "devDependencies": {
    "@livesql/client": "workspace:*",
    "@livesql/core": "workspace:*",
    "@vue/test-utils": "^2.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vue": "^3.0.0"
  }
}
