{
  "name": "@livesql/client",
  "version": "1.0.0-beta.1",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "description": "LiveSQL client SDK — framework-agnostic WebSocket client",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "@livesql/core": "workspace:*"
  }
}
